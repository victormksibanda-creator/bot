# ============================================================================
# Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in actual values
# NEVER commit .env file to version control!
#
# For Production Deployment:
# - Use secrets management (AWS Secrets Manager, Google Secret Manager, etc.)
# - Never use .env files in production
# - Use IAM roles and managed identities
#
# Security Principles:
# 1. Passwords in environment variables only
# 2. Rotate credentials regularly
# 3. Use different credentials for dev/staging/production
# 4. Log access to credentials
# 5. Audit trail for credential changes

# ============================================================================
# ENVIRONMENT SELECTION
# ============================================================================
TRADING_BOT_ENV=development
# Options: development, staging, production

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=forex_bot_user
DB_PASSWORD=your_secure_password_here
DB_NAME=forex_trading_bot

# Connection Pool Settings
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_CONNECTION_TIMEOUT=10

# ============================================================================
# BROKER CONFIGURATION
# ============================================================================
BROKER_NAME=Oanda
# Options: Saxo, IG, Oanda

BROKER_ACCOUNT_NUMBER=12345678
# For OANDA, use your OANDA account ID

BROKER_ACCOUNT_ID=
# Alternative alias for OANDA account ID

BROKER_ACCOUNT_PASSWORD=encrypted_broker_password
# Password for broker account (MUST be encrypted in production)

BROKER_SERVER=
# Broker server field is not required for REST-based brokers like OANDA

BROKER_API_KEY=your_broker_api_key
# For REST API access (OANDA API token)

# ============================================================================
# TRADING RISK MANAGEMENT
# ============================================================================
# These are default settings; can be overridden per user/strategy

RISK_PER_TRADE=2.0
# Percentage of account to risk per trade (typical: 1-3%)
# Example: 2% of $10,000 account = risk $200 per trade

DAILY_LOSS_LIMIT=5.0
# Maximum daily loss as % of account (typical: 5-10%)
# Trading stops when daily loss exceeds this
# Prevents revenge trading and emotional decisions

WEEKLY_LOSS_LIMIT=10.0
# Maximum weekly loss as % of account
# Provides longer-term loss limit

MAX_DRAWDOWN=20.0
# Maximum acceptable drawdown from peak (typical: 15-25%)
# Drawdown = (Peak Equity - Current Equity) / Peak Equity
# When exceeded, trading pauses to prevent psychological damage

MAX_MARGIN_LEVEL=50.0
# Maximum margin usage as % of equity (default: 50%)
# Margin Level = Equity / Used Margin * 100
# At 50%, margin level = 200%, which is safe threshold

MAX_CONCURRENT_TRADES=5
# Maximum number of open trades at same time
# Prevents over-concentration of risk

# ============================================================================
# TRADING HOURS
# ============================================================================
TRADING_HOURS_START=00:00
# Start time in UTC 24-hour format
# Example: 08:00 for 8 AM UTC
# Best forex hours: 08:00-22:00 UTC (London + US overlap)

TRADING_HOURS_END=23:59
# End time in UTC 24-hour format

# ============================================================================
# CURRENCY PAIRS
# ============================================================================
ENABLED_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD
# Comma-separated list of pairs to trade
# Most liquid pairs: EURUSD, GBPUSD, USDJPY, USDCHF

# ============================================================================
# STRATEGY CONFIGURATION
# ============================================================================
STRATEGY_TYPE=trend_following
# Options: scalping, trend_following, swing_trading, mean_reversion, etc.

STRATEGY_TIMEFRAME=H1
# Timeframe for main signals
# Options: M1, M5, M15, M30, H1, H4, D1, W1, MN

# ============================================================================
# TECHNICAL INDICATOR PARAMETERS
# ============================================================================
RSI_PERIOD=14
# RSI period for calculations

RSI_OVERBOUGHT=70
# RSI level considered overbought (typically 70)

RSI_OVERSOLD=30
# RSI level considered oversold (typically 30)

MA_FAST_PERIOD=20
# Fast moving average period

MA_SLOW_PERIOD=50
# Slow moving average period

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: Maximum detail, use for development
# INFO: Standard logging, use for production
# WARNING: Only warnings and errors

LOG_DIR=./logs
# Directory for log files
# Logs are rotated based on LOG_MAX_SIZE

LOG_MAX_SIZE=10485760
# Maximum log file size before rotation (default: 10MB)

LOG_BACKUP_COUNT=5
# Number of old log files to keep

# ============================================================================
# REST API CONFIGURATION (if using REST instead of MT5/MT4)
# ============================================================================
REST_API_BASE_URL=https://api.broker.com/v1
# Base URL for broker REST API

REST_API_TIMEOUT=30
# Timeout for API requests in seconds

# ============================================================================
# NOTIFICATIONS & ALERTS
# ============================================================================
SMTP_SERVER=smtp.gmail.com
# SMTP server for email notifications
# Example: smtp.gmail.com (Gmail), smtp.office365.com (Outlook)

SMTP_PORT=587
# SMTP port (typically 587 for TLS, 465 for SSL)

SMTP_USERNAME=your_email@gmail.com
# Email address to send from

SMTP_PASSWORD=your_app_password
# Email account password or app-specific password
# For Gmail: generate app password at myaccount.google.com/apppasswords

ALERT_EMAIL=your_email@gmail.com
# Email address to receive alerts

# ============================================================================
# MONITORING
# ============================================================================
ENABLE_METRICS=true
# Enable metrics collection and monitoring

METRICS_PORT=8000
# Port for metrics server (Prometheus, etc.)

# ============================================================================
# TESTING & DEVELOPMENT
# ============================================================================
MOCK_BROKER=false
# Use mock broker for testing (doesn't send real trades)
# Set to true for testing without risking real money

BACKTESTING_MODE=false
# Use historical data instead of real-time
# For backtesting strategies

# ============================================================================
# SECURITY NOTES
# ============================================================================
# IMPORTANT: Never commit .env file to git!
# Add to .gitignore:
#   .env
#   *.env
#   .env.local
#
# For production deployment in AWS:
#   Use AWS Secrets Manager
#   Use EC2 Instance Profiles/IAM Roles
#   Use parameter store for non-sensitive config
#
# For production deployment in GCP:
#   Use Google Secret Manager
#   Use Service Accounts
#   Use Secret Manager APIs
#
# For production deployment on VPS:
#   Use SSH key-based authentication
#   Store secrets in encrypted vault (HashiCorp Vault)
#   Use environment variables set by deployment system
#   Audit all credential access
